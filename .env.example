# Tier 2 (proxy/tier2.py) — Gemma contextual classifier via Fireworks AI.
# Required: without this, Tier 2 fails safe (returns WARN) rather than erroring.
FIREWORKS_API_KEY=

# Optional — defaults are set in tier2.py.
# Gemma is not on Fireworks serverless; deploy on-demand (`firectl create deployment
# accounts/fireworks/models/gemma-4-31b-it`) and put the returned id/deployment
# string here. For a quick serverless smoke test, use a Llama model instead, e.g.
# accounts/fireworks/models/llama-v3p3-70b-instruct.
# FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-31b-it

# Optional — point at a self-hosted Gemma endpoint (e.g. AMD Developer Cloud /
# ROCm) instead of Fireworks once that's deployed.
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
